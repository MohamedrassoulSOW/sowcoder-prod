NODE_ENV=production

# Hostinger fournit souvent PORT automatiquement.
# Laissez vide dans hPanel si un port est injecté.
PORT=3001

# Domaine public du site
CORS_ORIGIN=https://ms.sowcoder.com,https://www.ms.sowcoder.com

# Auth
JWT_SECRET=CHANGE_ME_SUPER_SECRET_LONG_RANDOM
JWT_EXPIRES_IN=7d
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# Compte admin initial (créé/mis à jour au démarrage)
ADMIN_NAME=Administrateur SowCoder
ADMIN_EMAIL=admin@sowcoder.sn
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Notifications email (optionnel)
CONTACT_EMAIL=contact@sowcoder.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
