# SowCoder — Hostinger / Apache (document root = ce dossier)

<IfModule mod_mime.c>
    AddType application/javascript .js .mjs
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType application/wasm .wasm
    AddType application/json .json
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Bloquer l'accès aux sources React si elles ont été uploadées par erreur
    RewriteRule ^src/ - [F,L]

    # Fichiers statiques réels
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API Symfony + fichiers uploadés (stockés hors public/)
    RewriteRule ^api(?:/|$) index.php [L,QSA]
    RewriteRule ^uploads(?:/|$) index.php [L,QSA]

    # Application React (/, /blog, /blog/slug, …)
    RewriteRule ^ index.html [L]
</IfModule>

Options -Indexes

DirectoryIndex index.html index.php
