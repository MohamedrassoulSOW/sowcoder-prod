# API Node.js (server/.env ou racine .env)
# Base locale SQLite : server/data/sowcoder.db
# Démarrage : npm run dev:server  ou  npm run dev:all

PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Notifications (optionnel — sans SMTP, les messages sont stockés localement)
CONTACT_EMAIL=contact@sowcoder.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Admin — pour consulter les soumissions : GET /api/admin/submissions
# Header: x-api-key: votre_cle_secrete
ADMIN_API_KEY=changez-moi-en-production
JWT_SECRET=changez-cette-cle-secrete-en-production
JWT_EXPIRES_IN=7d

# Compte administrateur (créé au démarrage si inexistant)
ADMIN_NAME=Administrateur SowCoder
ADMIN_EMAIL=admin@sowcoder.sn
ADMIN_PASSWORD=ChangezMoi123!

# Frontend (Vite)
VITE_API_URL=
