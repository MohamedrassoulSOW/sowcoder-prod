# Bloquer l'exécution de scripts dans les uploads
<FilesMatch "\.(?i:php|phtml|php3|php4|php5|phar|cgi|pl|asp|aspx)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
